{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin-login.html"
    },
    {
      "src": "/admin/dashboard",
      "dest": "/admin-dashboard.html"
    },
    {
      "src": "/admin/users",
      "dest": "/admin-user-manager.html"
    },
    {
      "src": "/admin/content",
      "dest": "/admin-content-manager.html"
    },
    {
      "src": "/admin/analytics",
      "dest": "/admin-analytics.html"
    },
    {
      "src": "/admin/settings",
      "dest": "/admin-settings.html"
    },
    {
      "src": "/admin/notifications",
      "dest": "/admin-notifications.html"
    },
    {
      "src": "/per-ankh",
      "dest": "/per-ankh.html"
    },
    {
      "src": "/community",
      "dest": "/community.html"
    },
    {
      "src": "/events",
      "dest": "/events.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/donate",
      "dest": "/donate.html"
    },
    {
      "src": "/member/login",
      "dest": "/member-login.html"
    },
    {
      "src": "/protocols",
      "dest": "/protocols.html"
    },
    {
      "src": "/calculator",
      "dest": "/calculator.html"
    },
    {
      "src": "/crystaltech",
      "dest": "/crystaltech.html"
    },
    {
      "src": "/mamayana",
      "dest": "/mamayana.html"
    },
    {
      "src": "/moudoubaqui",
      "dest": "/moudoubaqui.html"
    },
    {
      "src": "/jon",
      "dest": "/jon.html"
    },
    {
      "src": "/shanna",
      "dest": "/Shanna1.html"
    },
    {
      "src": "/become-a-member",
      "dest": "/become-a-member.html"
    },
    {
      "src": "/vendor-registration",
      "dest": "/vendor-registration.html"
    },
    {
      "src": "/ceremony-and-safety",
      "dest": "/ceremony-and-safety.html"
    },
    {
      "src": "/community-partnership",
      "dest": "/communitypartnership.html"
    },
    {
      "src": "/sacred-community",
      "dest": "/sacredcommunityrelationships.html"
    },
    {
      "src": "/women-empowerment",
      "dest": "/women'sempowerment.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  }
}
